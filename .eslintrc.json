{
  "env": {
    "node": true,
    "es2022": true
  },
  "extends": [
    "standard",
    "plugin:@typescript-eslint/recommended",
    "prettier"
  ],
  "parser": "@typescript-eslint/parser",
  "plugins": [
    "@typescript-eslint"
  ],
  "parserOptions": {
    "sourceType": "module"
  },
  "ignorePatterns": [
    "dist"
  ]
}